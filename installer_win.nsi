  !insertmacro DEBUG_MSG "Creating shortcuts"
  SetRebootFlag false
  StrCmp "CurrentUser" $MultiUser.InstallMode currentuser2
  SetShellVarContext all
  Call CreateShortCuts ; Call with elevation just in case it is an all users installation
  Goto MegaShortcutsCreated
currentuser2:
  SetShellVarContext current
  ${UAC.CallFunctionAsUser} CreateShortCuts
MegaShortcutsCreated:
SectionEnd

Function CheckDiskSpace
  SectionGetSize ${SEC01} $0
  IntOp $0 $0 + 10240

  ${GetRoot} "$INSTDIR" $1
  ${DriveSpace} "$1" "/D=F /S=K" $2

  ${If} $2 == ""
    Return
  ${EndIf}

  IntCmpU $2 $0 enough_space disk_full enough_space

disk_full:
  !insertmacro ExitWithError ${ERROR_DISK_FULL} "There is not enough disk space available to install MEGA Desktop App."

enough_space:
FunctionEnd

Section -AdditionalIcons

SectionEnd

Function WriteOnLocalMachineReg
  WriteRegStr ${PRODUCT_UNINST_ROOT_KEY_LOCAL_MACHINE} "${PRODUCT_DIR_REGKEY}" "" "$INSTDIR\MEGAsync.exe"
  WriteRegStr ${PRODUCT_UNINST_ROOT_KEY_LOCAL_MACHINE} "${PRODUCT_UNINST_KEY}" "DisplayName" "${PRODUCT_NAME}"
  WriteRegStr ${PRODUCT_UNINST_ROOT_KEY_LOCAL_MACHINE} "${PRODUCT_UNINST_KEY}" "DisplayVersion" "${PRODUCT_VERSION}"
  WriteRegStr ${PRODUCT_UNINST_ROOT_KEY_LOCAL_MACHINE} "${PRODUCT_UNINST_KEY}" "UninstallString" "$INSTDIR\${UNINSTALLER_NAME}"
  WriteRegStr ${PRODUCT_UNINST_ROOT_KEY_LOCAL_MACHINE} "${PRODUCT_UNINST_KEY}" "DisplayIcon" "$INSTDIR\MEGAsync.exe"
  WriteRegStr ${PRODUCT_UNINST_ROOT_KEY_LOCAL_MACHINE} "${PRODUCT_UNINST_KEY}" "URLInfoAbout" "${PRODUCT_WEB_SITE}"
  WriteRegStr ${PRODUCT_UNINST_ROOT_KEY_LOCAL_MACHINE} "${PRODUCT_UNINST_KEY}" "Publisher" "${PRODUCT_PUBLISHER}"
  WriteRegStr ${PRODUCT_UNINST_ROOT_KEY_LOCAL_MACHINE} "${PRODUCT_UNINST_KEY}" "${PRODUCT_STARTMENU_REGVAL}" "$ICONS_GROUP"
FunctionEnd

Function WriteOnCurrentUserReg
  WriteRegStr ${PRODUCT_UNINST_ROOT_KEY_CURRENT_USER} "${PRODUCT_DIR_REGKEY}" "" "$INSTDIR\MEGAsync.exe"
  WriteRegStr ${PRODUCT_UNINST_ROOT_KEY_CURRENT_USER} "${PRODUCT_UNINST_KEY}" "DisplayName" "${PRODUCT_NAME}"
  WriteRegStr ${PRODUCT_UNINST_ROOT_KEY_CURRENT_USER} "${PRODUCT_UNINST_KEY}" "DisplayVersion" "${PRODUCT_VERSION}"
  WriteRegStr ${PRODUCT_UNINST_ROOT_KEY_CURRENT_USER} "${PRODUCT_UNINST_KEY}" "UninstallString" "$INSTDIR\${UNINSTALLER_NAME}"
  WriteRegStr ${PRODUCT_UNINST_ROOT_KEY_CURRENT_USER} "${PRODUCT_UNINST_KEY}" "DisplayIcon" "$INSTDIR\MEGAsync.exe"
  WriteRegStr ${PRODUCT_UNINST_ROOT_KEY_CURRENT_USER} "${PRODUCT_UNINST_KEY}" "URLInfoAbout" "${PRODUCT_WEB_SITE}"
  WriteRegStr ${PRODUCT_UNINST_ROOT_KEY_CURRENT_USER} "${PRODUCT_UNINST_KEY}" "Publisher" "${PRODUCT_PUBLISHER}"
  WriteRegStr ${PRODUCT_UNINST_ROOT_KEY_CURRENT_USER} "${PRODUCT_UNINST_KEY}" "${PRODUCT_STARTMENU_REGVAL}" "$ICONS_GROUP"
FunctionEnd

Section -Post
  ;First remove the HKLM as it may contain old info from old installers 
  !insertmacro CheckHKLMUninstallInfo
  StrCmp "CurrentUser" $MultiUser.InstallMode currentuser

  ;Called if we are installing the app for all the users
  Call WriteOnLocalMachineReg
  Goto continuePost
currentuser:
  ${UAC.CallFunctionAsUser} WriteOnCurrentUserReg
continuePost:
  AccessControl::SetFileOwner "$INSTDIR\MEGA Website.url" "$USERNAME"
  AccessControl::GrantOnFile "$INSTDIR\MEGA Website.url" "$USERNAME" "GenericRead + GenericWrite"

  Delete "$INSTDIR\NSIS.Library.RegTool*.exe"
SectionEnd

Function un.onInit

  ${GetParameters} $R0
  ClearErrors
  ${GetOptions} $R0 "/cleanup" $0
  ${IfNot} ${Errors}
    StrCpy $0 0
cleanup_wait:
    Sleep 1000
    ClearErrors
    Delete "$INSTDIR\${UNINSTALLER_NAME}"
    IfErrors cleanup_retry cleanup_done
cleanup_retry:
    IntOp $0 $0 + 1
    IntCmp $0 10 cleanup_done cleanup_wait cleanup_wait
cleanup_done:
    RMDir /r "$INSTDIR"
    Quit
  ${EndIf}
  !insertmacro MULTIUSER_UNINIT
  StrCpy $APP_NAME "${PRODUCT_NAME}"
  !insertmacro CheckUserToRunElevated
  !insertmacro MUI_UNGETLANGUAGE

FunctionEnd

Function un.UninstallSyncs
  ExecDos::exec "$INSTDIR\MEGAsync.exe /uninstall"
FunctionEnd

Function un.RemoveCurrentUserReg
  DeleteRegKey ${PRODUCT_UNINST_ROOT_KEY_CURRENT_USER} "${PRODUCT_UNINST_KEY}"
  DeleteRegKey ${PRODUCT_UNINST_ROOT_KEY_CURRENT_USER} "${PRODUCT_DIR_REGKEY}"
FunctionEnd

Function un.RemoveCommonCurrentUserReg
  DeleteRegKey ${PRODUCT_UNINST_ROOT_KEY_CURRENT_USER} "${PRODUCT_DIR_USER_REGKEY}"
  DeleteRegKey /ifempty ${PRODUCT_UNINST_ROOT_KEY_CURRENT_USER} "${PRODUCT_DIR_PUBLISHER_REGPATH}"
 FunctionEnd
 
